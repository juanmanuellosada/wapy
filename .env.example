# Sentry — pegar el DSN desde https://sentry.io/settings/.../projects/.../keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Opcional, para upload de sourcemaps en CI:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Mercado Pago + billing
# Access Token de producción (Credenciales de producción en el panel de tu app de MP)
MP_ACCESS_TOKEN=
# Clave secreta del webhook (sección Webhooks de la app en MP)
MP_WEBHOOK_SECRET=
# Secreto para proteger el cron /api/cron/check-subscriptions (Authorization: Bearer)
CRON_SECRET=
# ID del Preapproval Plan "Inicial" CON 14 días de prueba ($7.000/mes)
MP_PREAPPROVAL_PLAN_ID_INICIAL=
# ID del Preapproval Plan "Inicial" SIN prueba (reactivación / returning)
MP_PREAPPROVAL_PLAN_ID_INICIAL_RETURNING=
# ID del Preapproval Plan "Medio" CON 14 días de prueba ($9.000/mes)
MP_PREAPPROVAL_PLAN_ID_MEDIO=
# ID del Preapproval Plan "Medio" SIN prueba (reactivación / returning)
MP_PREAPPROVAL_PLAN_ID_MEDIO_RETURNING=
# ID del Preapproval Plan "Pro" CON 14 días de prueba ($18.000/mes)
MP_PREAPPROVAL_PLAN_ID_PRO=
# ID del Preapproval Plan "Pro" SIN prueba (reactivación / returning)
MP_PREAPPROVAL_PLAN_ID_PRO_RETURNING=
