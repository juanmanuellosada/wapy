# Send Email Hook — generado por el dashboard de Supabase al crear el hook (Auth → Hooks → Send Email)
# Formato: v1,whsec_<base64_secret>. El mismo valor va como SEND_EMAIL_HOOK_SECRET en Vercel.
SEND_EMAIL_HOOK_SECRET=

# Sentry — pegar el DSN desde https://sentry.io/settings/.../projects/.../keys/
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Opcional, para upload de sourcemaps en CI:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ---------------------------------------------------------------------------
# Cifrado de tokens de Mercado Pago (secrets por-tienda)
# ---------------------------------------------------------------------------
# Clave AES-256-GCM usada para cifrar los tokens OAuth de Mercado Pago de cada
# dueño antes de persistirlos en la base de datos.
#
# ⚠ CRÍTICO: Si esta clave se pierde, los tokens cifrados son irrecuperables y
#   los dueños deberán reconectar su cuenta de Mercado Pago desde cero.
#   Guardala en un gestor de secretos (Vercel Secrets / Vault) y hacé un backup
#   seguro antes de rotar.
#
# Formato: clave base64 de 32 bytes (256 bits).
# Generá una nueva con: openssl rand -base64 32
MP_TOKEN_ENC_KEY=

# ---------------------------------------------------------------------------
# Mercado Pago OAuth — por-tienda (checkout de compradores)
# ---------------------------------------------------------------------------
# Client ID y Client Secret de la aplicación OAuth de Mercado Pago.
# Registrar la app en: https://www.mercadopago.com.ar/developers/panel/app
# En la configuración de la app, agregar como Redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/mp/oauth/callback
# (reemplazar {NEXT_PUBLIC_APP_URL} con la URL pública de la app, ej. https://wapy.app)
MP_OAUTH_CLIENT_ID=
MP_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Mercado Pago + billing
# Access Token de producción (Credenciales de producción en el panel de tu app de MP)
MP_ACCESS_TOKEN=
# Public Key de producción — YA NO REQUERIDA. Se usaba para MP Bricks (captura in-app);
# el flujo ahora usa checkout hosteado (init_point) que no necesita la public key en el cliente.
# Dejar comentado hasta confirmar que ningún entorno la usa.
# NEXT_PUBLIC_MP_PUBLIC_KEY=
# Clave secreta del webhook de billing (sección Webhooks de la app en MP)
MP_WEBHOOK_SECRET=
# Clave secreta del webhook de pagos de pedidos (sección Webhooks de la app en MP).
# Debe ser DISTINTA a MP_WEBHOOK_SECRET — son dos webhooks separados con secrets propios.
MP_ORDERS_WEBHOOK_SECRET=
# Secreto para proteger el cron /api/cron/check-subscriptions (Authorization: Bearer)
CRON_SECRET=
# DEPRECADO — se elimina al final del rollout de app-managed-trial-billing.
# El cobro ahora va por API sin plan asociado; estas variables ya no se usan.
# MP_PREAPPROVAL_PLAN_ID_INICIAL=
# MP_PREAPPROVAL_PLAN_ID_INICIAL_RETURNING=
# MP_PREAPPROVAL_PLAN_ID_MEDIO=
# MP_PREAPPROVAL_PLAN_ID_MEDIO_RETURNING=
# MP_PREAPPROVAL_PLAN_ID_PRO=
# MP_PREAPPROVAL_PLAN_ID_PRO_RETURNING=
