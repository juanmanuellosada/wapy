# Supabase — get from https://supabase.com/dashboard/project/gtiujuarwoatjekmljhn/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=  # SERVER ONLY — never expose to browser

# Resend — get from https://resend.com/api-keys
# Note: domain wapy.com.ar must be verified in Resend before emails will send.
RESEND_API_KEY=

# App URL — used in invite emails and OAuth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000  # In prod: https://wapy.com.ar
